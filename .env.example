# ============================================================
# 環境變數範本 - 請複製成 .env 後填入實際值
#   cp .env.example .env
# 注意: .env 不應該 commit 到 git (請確認 .gitignore 有列)
# ============================================================

# ---------- MySQL ----------
# 在 docker compose 內: MYSQL_HOST=mysql (服務名稱)
# 在本機直接跑: MYSQL_HOST=127.0.0.1
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ACCOUNT=root
MYSQL_PASSWORD=Aa1234567890

# ---------- RabbitMQ ----------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
WORKER_ACCOUNT=worker
WORKER_PASSWORD=worker

# ---------- Docker Image 版本 ----------
# 對應 docker hub linsamtw/tibame_crawler 的 tag
DOCKER_IMAGE_VERSION=0.0.9
